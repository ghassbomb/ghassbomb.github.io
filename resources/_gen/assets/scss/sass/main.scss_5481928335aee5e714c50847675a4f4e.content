@font-face{font-display:swap;font-family:latin modern roman;font-style:normal;font-weight:400;src:url(../fonts/lmroman10-regular.otf)format("opentype")}@font-face{font-display:swap;font-family:latin modern roman;font-style:normal;font-weight:700;src:url(../fonts/lmroman10-bold.otf)format("opentype")}@font-face{font-display:swap;font-family:latin modern roman;font-style:italic;font-weight:400;src:url(../fonts/lmroman10-italic.otf)format("opentype")}@font-face{font-display:swap;font-family:latin modern roman;font-style:italic;font-weight:700;src:url(../fonts/lmroman10-bolditalic.otf)format("opentype")}@font-face{font-display:swap;font-family:latin modern roman sc;font-style:italic;font-weight:400;src:url(../fonts/lmromancaps10-oblique.otf)format("opentype")}@font-face{font-display:swap;font-family:latin modern roman sc;font-style:normal;font-weight:400;src:url(../fonts/lmromancaps10-regular.otf)format("opentype")}*{text-rendering:optimizeLegibility;box-sizing:border-box;margin:0;padding:0}::-webkit-scrollbar{background-color:#282828;height:8px;width:8px}::-webkit-scrollbar ::-webkit-scrollbar-thumb{background-color:#928374}::-webkit-scrollbar ::-webkit-scrollbar-thumb:hover{background-color:#fe8019}html{scroll-behavior:smooth;font-size:14px;background-color:#282828;color:#fbf1c7}html a{color:#fb4934;text-decoration:none}html a:hover{color:#cc2412}html details{margin-top:2rem}html .link{color:#fbf1c7}html .link:hover{color:#a89984}html time{color:#928374;margin-left:1rem;min-width:5rem}html hr{margin-bottom:.5rem;margin-top:2rem}html h1,html h2,html h3,html h4,html h5,html h6{letter-spacing:-.03rem;line-height:1.2}html h1{font-size:3.375rem}html h2{font-size:1.7rem}html h3{font-size:1.5rem}html h4{font-size:1rem}html #content{display:grid;grid-template-columns:19.5vw 60vw 19.5vw;font-family:latin modern roman,serif}html #content header{display:flex;flex-direction:column;align-items:center;grid-column:2/3;margin-bottom:2rem;font-family:latin modern roman sc,serif;font-variant:small-caps}html #content header h1{display:flex;flex-wrap:wrap;letter-spacing:.6rem;text-align:center;font-size:3.375rem;text-shadow:.5px .5px #333e51,1px 1px #333e51,1.5px 1.5px #333e51,2px 2px #333e51,2.5px 2.5px #333e51,3px 3px #333e51,3.5px 3.5px #333e51,4px 4px #333e51,4.5px 4.5px #333e51,5px 5px #333e51,5.5px 5.5px #333e51,6px 6px #333e51,6.5px 6.5px #333e51,7px 7px #333e51}html #content header nav{display:flex;justify-content:space-between;flex-wrap:wrap;font-weight:700;padding:0 1rem;max-width:40rem;width:100%}html #content main{display:flex;flex-direction:column;padding:0 7vw;grid-column:2/3;width:100%}html #content main h1{text-align:center}html #content main .post-group ul{border-left:#928374 solid 1px;list-style-type:none;margin-left:.5rem;padding-left:1rem}html #content main .post-group ul li{align-items:center;display:flex;flex-direction:row;justify-content:space-between;line-height:1.5}html #content main .post-group ul li time{text-align:right}html #content main .post{margin-bottom:1rem}html #content main .post .post-title{font-size:2.25rem}html #content main .post h2{align-items:center;flex-direction:row;justify-content:space-between;flex-wrap:wrap}html #content #left-sidebar{grid-column:1/2;margin-top:2rem;padding-left:2rem;position:sticky;top:2rem;align-self:start}html #content #left-sidebar #post-summary{font-family:latin modern roman sc,serif;font-size:.8rem;border-left:1px solid #928374}html #content #left-sidebar #post-summary p{text-decoration:none;display:block;margin-left:1rem;transition:all 100ms ease-in-out}html #content #left-sidebar .featured-posts{font-family:latin modern roman sc,serif;font-size:.8rem;border-left:1px solid #928374;padding-left:1rem;margin-top:2rem}html #content #left-sidebar .series a{font-style:normal;font-family:latin modern roman sc,serif;color:#8ec07c}html #content #left-sidebar .series a:hover{color:#618355}html #content #left-sidebar .series p{font-style:italic}html #content #left-sidebar #series{margin-top:2rem}html #content #left-sidebar #series a{font-style:normal;font-family:latin modern roman sc,serif;color:#8ec07c}html #content #left-sidebar #series a:hover{color:#689d6a}html #content #left-sidebar #series a ol{margin-left:1.2rem}html #content #right-sidebar{grid-column:3/4;position:sticky;top:2rem;align-self:start}html #content #right-sidebar #TableOfContents{font-family:latin modern roman sc,serif;font-size:.8rem;margin-top:2rem;padding-left:0;border-left:1px solid #928374}html #content #right-sidebar #TableOfContents a{text-decoration:none;display:block;padding:.125rem 0;color:#928374;transition:all 100ms ease-in-out}html #content #right-sidebar #TableOfContents a:hover,html #content #right-sidebar #TableOfContents a:focus{color:#a89984}html #content #right-sidebar #TableOfContents ul,html #content #right-sidebar #TableOfContents ol{list-style:none;margin:0;padding:0}html #content #right-sidebar #TableOfContents li{margin-left:1rem}html #content #right-sidebar #TableOfContents a.active{color:#fbf1c7;font-weight:700}html #content footer{grid-column:2/3;align-items:center;display:flex;font-size:.75rem;flex-direction:column;margin-bottom:1rem;margin-top:1rem}html #content footer .footnote{margin-bottom:.3rem;text-align:center}html #content article{padding-top:1rem}html #content article a.footnote-ref::before{content:"["}html #content article a.footnote-ref::after{content:"]"}html #content article blockquote,html #content article div,html #content article h1,html #content article h2,html #content article h3,html #content article h4,html #content article h5,html #content article h6,html #content article p,html #content article pre,html #content article ol,html #content article table,html #content article ul{margin-bottom:1rem}html #content article h1,html #content article h2,html #content article h3,html #content article h4,html #content article h5,html #content article h6{margin-top:1.5rem;margin-bottom:.75rem}html #content article blockquote{border-left:#fe8019 2px solid;background-color:#504945;margin:1.5rem 0;padding:.5rem 0;padding-left:1.3rem}html #content article blockquote p{line-height:1.3rem;font-size:.9rem;margin-bottom:0}html #content article code{font-family:courier new,Courier,monospace;font-size:.85rem;background-color:#3c3836;border-radius:.2rem;padding:.2rem}html #content article img{max-width:100%}html #content article p{text-align:left;line-height:1.5rem;max-width:50vw}html #content article pre{background-color:#928374;margin:1.5rem 0;padding:.5rem 0;padding-left:1.3rem}html #content article pre code{padding:0}html #content article table{width:100%;border-collapse:collapse;border:1px solid #fbf1c7}html #content article th,html #content article td{padding:.4rem;text-align:left;border:1px solid #fbf1c7}html #content article th{font-family:latin modern roman sc,serif;text-transform:uppercase;font-variant:small-caps;font-size:.8rem;padding:.3rem}html #content article tr:nth-child(even){background-color:#282828}html #content article td{color:#fbf1c7}html #content article ol,html #content article ul{margin-left:1.5rem}html #content .paginator{display:flex;align-items:flex-end;flex-direction:row;justify-content:space-between;margin-top:1rem}html #content .comment{margin-top:1rem}html #content .metadata{display:flex;flex-wrap:wrap;font-family:latin modern roman sc,serif;color:#928374;font-size:.8rem;display:flex;flex-direction:column}html #content .metadata .grey{margin-bottom:1rem}html #content .metadata time{margin-left:0;justify-self:flex-end}html #content .metadata span{margin-right:1rem}html #content #share-buttons{margin-top:.6rem}html #content .summary{font-style:italic;margin-top:.5rem;font-size:.9rem;line-height:1.5}@media only screen and (min-width:768px){html{font-size:22px}}